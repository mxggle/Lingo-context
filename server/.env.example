AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PROMPT_CACHE_LOG_HITS=true
# Explicit caching: cache system instructions via CachedContent API (guaranteed savings)
# Set to 'false' to disable. Default TTL is 3600s (1 hour).
GEMINI_EXPLICIT_CACHE=true
GEMINI_CACHE_TTL=3600
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
CODEX_MODEL=codex
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
CODEX_HOME=
PORT=3000
DATABASE_URL=mysql://user:password@mysql:3306/LingoContext
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
NODE_ENV=production

ALLOWED_ORIGINS=http://localhost:3000,https://example.com
CHROME_EXTENSION_IDS=
