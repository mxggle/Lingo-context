{
    "version": 2,
    "name": "lingo-context-api",
    "outputDirectory": "server",
    "builds": [
        {
            "src": "server/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server/index.js"
        }
    ]
}
